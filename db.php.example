<?php
/**
 * @file: db.php.example
 * @description: Пример файла конфигурации БД. 
 * ПЕРЕИМЕНУЙТЕ В db.php И ЗАПОЛНИТЕ ДАННЫЕ.
 */

if (session_status() === PHP_SESSION_NONE && PHP_SAPI !== 'cli') {
    session_start();
}

$host = '127.0.0.1';
$dbname = 'ВАША_БАЗА_ДАННЫХ';
$user = 'ВАШ_ПОЛЬЗОВАТЕЛЬ';
$pass = 'ВАШ_ПАРОЛЬ';

try {
    $pdo = new PDO("mysql:host=$host;dbname=$dbname;charset=utf8mb4", $user, $pass);
    $pdo->setAttribute(PDO::ATTR_ERRMODE, PDO::ERRMODE_EXCEPTION);
    $pdo->setAttribute(PDO::ATTR_DEFAULT_FETCH_MODE, PDO::FETCH_ASSOC);
} catch (PDOException $e) {
    die("Ошибка подключения к базе данных: " . $e->getMessage());
}

/**
 * Получение настройки из БД (таблица settings)
 */
function getSetting($key, $pdo) {
    try {
        $stmt = $pdo->prepare("SELECT setting_value FROM settings WHERE setting_key = ?");
        $stmt->execute([$key]);
        return $stmt->fetchColumn();
    } catch (Exception $e) {
        return null;
    }
}

/**
 * Отправка Telegram уведомлений (опционально)
 */
function sendTelegramMessage($token, $chat_id, $message) {
    if (!$token || !$chat_id) return ['ok' => false, 'error' => 'Настройки Telegram не заданы'];
    
    $url = "https://api.telegram.org/bot$token/sendMessage";
    $data = [
        'chat_id' => $chat_id,
        'text' => $message,
        'parse_mode' => 'HTML'
    ];

    $ch = curl_init();
    curl_setopt($ch, CURLOPT_URL, $url);
    curl_setopt($ch, CURLOPT_POST, true);
    curl_setopt($ch, CURLOPT_RETURNTRANSFER, true);
    curl_setopt($ch, CURLOPT_POSTFIELDS, http_build_query($data));
    curl_setopt($ch, CURLOPT_SSL_VERIFYPEER, true); // Включаем проверку для Telegram
    
    $result = curl_exec($ch);
    $error = curl_error($ch);
    curl_close($ch);

    if ($result) {
        return json_decode($result, true);
    }
    return ['ok' => false, 'error' => 'Ошибка API Telegram: ' . $error];
}
?>
